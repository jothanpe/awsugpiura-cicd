# Copia este archivo a .env y completa los valores.
# El archivo .env NO se versiona (está en .gitignore).

# (Opcional) Perfil de AWS a usar en bootstrap/deploy/destroy.
# Solo aplica a los comandos npm run bootstrap|deploy|destroy (que usan
# dotenv-cli para inyectar estas variables al CLI de CDK). Déjalo comentado
# para usar el perfil/credenciales por defecto.
# AWS_PROFILE=mi-perfil
# AWS_REGION=us-east-1

# Repo de GitHub en formato "owner/repo"
GITHUB_REPO=TU_USUARIO/CICD101

# Rama que dispara el pipeline
GITHUB_BRANCH=main

# ARN de la CodeConnection (CodeStar Connection) ya creada y en estado Available.
# Obténlo con:
#   aws codeconnections list-connections \
#     --query "Connections[].{Name:ConnectionName,Status:ConnectionStatus,Arn:ConnectionArn}" \
#     --output table
CODESTAR_CONNECTION_ARN=arn:aws:codeconnections:us-east-1:111122223333:connection/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
